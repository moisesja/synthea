{
  "name": "nsclc_drug_interactions",
  "remarks": [
    "Beta-owned Phase 1 submodule for active medication lists used in drug-interaction queries.",
    "Reads nsclc_egfr_positive, nsclc_pdl1_tps_category, nsclc_prior_platinum, and nsclc_stage."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "nsclc_egfr_positive",
            "operator": "==",
            "value": true
          },
          "transition": "MedicationOrder_Osimertinib"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "nsclc_prior_platinum",
            "operator": "==",
            "value": true
          },
          "transition": "MedicationOrder_Pembrolizumab_PostPlatinum"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "nsclc_pdl1_tps_category",
            "operator": "==",
            "value": "high"
          },
          "transition": "MedicationOrder_Pembrolizumab_FirstLine"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "nsclc_stage",
            "operator": "==",
            "value": "II"
          },
          "transition": "MedicationOrder_Carboplatin_Adjuvant"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "nsclc_stage",
            "operator": "==",
            "value": "I"
          },
          "transition": "MedicationOrder_Prednisone_Localized"
        },
        {
          "transition": "MedicationOrder_Carboplatin_Advanced"
        }
      ]
    },
    "MedicationOrder_Osimertinib": {
